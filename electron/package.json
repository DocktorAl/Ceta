{
  "name": "ceta-mermaid-editor",
  "version": "1.0.0",
  "description": "CETA Mermaid & SVG diagram editor — desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "uk.org.stelizabeths.ceta",
    "productName": "CETA Diagram Editor",
    "files": ["main.js", "index.html"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}
